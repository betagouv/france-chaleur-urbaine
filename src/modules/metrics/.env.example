# Metrics module

# Bearer token required to access GET /api/metrics. Endpoint disabled (404) when unset.
# Generate with: openssl rand -hex 32
METRICS_AUTH_TOKEN=

# Auto-injected by Scalingo, used as default labels on every metric:
# APP=france-chaleur-urbaine        # → label `app`
# CONTAINER=web-1                   # → label `instance`
