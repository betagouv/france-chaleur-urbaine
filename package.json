{
  "name": "france-chaleur-urbaine",
  "version": "1.0.0",
  "private": false,
  "engines": {
    "node": "24",
    "pnpm": "10"
  },
  "type": "module",
  "description": "Un service public pour faciliter et accélérer les raccordements aux réseaux de chaleur.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betagouv/france-chaleur-urbaine.git"
  },
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/betagouv/france-chaleur-urbaine/issues"
  },
  "homepage": "https://github.com/betagouv/france-chaleur-urbaine#readme",
  "scripts": {
    "dev": "next dev",
    "scan": "pnpm dev & npx react-scan@latest localhost:3000",
    "dev:webpack": "next dev",
    "dev:debug": "API_DEBUG_MODE=true pnpm dev",
    "dev:email": "NEXT_PUBLIC_SITE_URL=http://localhost:3000 NODE_ENV=test email dev --dir src/modules/email/react-email/templates --port 3001",
    "build": "NODE_OPTIONS=\"--max-old-space-size=8192\" next build",
    "build:analyze": "TURBOPACK_STATS=1 pnpm build",
    "deadcode": "pnpx knip",
    "clean": "rm -Rf node_modules && rm -Rf .next && pnpm i",
    "start": "next start -p $PORT",
    "start:clock": "tsx src/modules/jobs/server/clock.ts",
    "dev:clock": "tsx --watch src/modules/jobs/server/clock.ts",
    "prepare": "husky",
    "lint": "biome check --max-diagnostics 50 .",
    "lint:fix": "biome check --max-diagnostics 50 --write .",
    "lint:fix:file": "biome check --write",
    "lint:ci": "biome ci --diagnostic-level error .",
    "test": "vitest run",
    "test:a11y": "playwright test",
    "test:a11y:report": "playwright show-report test-results/a11y-report",
    "test:watch": "vitest dev",
    "test:coverage": "vitest run --coverage",
    "test:db:migrate": "DATABASE_URL=postgres://fcu_test:fcu_test_pass@localhost:5433/fcu_test pnpm db:migrate",
    "cli": "tsx scripts/cli.ts",
    "db:migrate": "tsx src/server/db/migrations/migrator.ts up",
    "db:migrate:down": "tsx src/server/db/migrations/migrator.ts down",
    "db:bootstrap": "pnpm cli db:bootstrap",
    "db:pull:dev": "./scripts/copyRemoteTableToLocal.sh dev",
    "db:pull:prod": "./scripts/copyRemoteTableToLocal.sh prod",
    "db:push:dev": "./scripts/copyLocalTableToRemote.sh dev",
    "db:push:prod": "./scripts/copyLocalTableToRemote.sh prod",
    "db:sync": "pnpm cli db:sync",
    "db:verify": "pnpm db:introspect --verify",
    "postinstall": "node scripts/postinstall.mjs",
    "scalingo-postbuild": "./scripts/migrate.sh && pnpm build && next-sitemap",
    "predev": "only-include-used-icons --silent",
    "prebuild": "only-include-used-icons",
    "talisman:add-exception": "node-talisman -i -g pre-commit",
    "ts": "NODE_OPTIONS=\"--max-old-space-size=8192\" pnpm tsc --build --clean && pnpm tsc"
  },
